{
  "name": "@scania/tegel-lite",
  "version": "0.1.0",
  "description": "Styles-only library for Tegel Design System (Beta)",
  "type": "module",
  "keywords": [
    "tegel",
    "scania",
    "design-system",
    "css",
    "styles",
    "components",
    "ui",
    "design-tokens",
    "lite",
    "no-js"
  ],
  "homepage": "https://tegel.scania.com",
  "bugs": {
    "url": "https://github.com/scania-digital-design-system/tegel/issues"
  },
  "style": "dist/global.css",
  "exports": {
    ".": "./dist/global.css",
    "./package.json": "./package.json",
    "./global.css": "./dist/global.css",
    "./scania-variables.css": "./dist/scania-variables.css",
    "./traton-variables.css": "./dist/traton-variables.css",
    "./components.css": "./dist/components.css",
    "./tl-accordion.css": "./dist/tl-accordion.css",
    "./tl-banner.css": "./dist/tl-banner.css",
    "./tl-block.css": "./dist/tl-block.css",
    "./tl-breadcrumbs.css": "./dist/tl-breadcrumbs.css",
    "./tl-button.css": "./dist/tl-button.css",
    "./tl-card.css": "./dist/tl-card.css",
    "./tl-checkbox.css": "./dist/tl-checkbox.css",
    "./tl-datetime.css": "./dist/tl-datetime.css",
    "./tl-divider.css": "./dist/tl-divider.css",
    "./tl-footer.css": "./dist/tl-footer.css",
    "./tl-header.css": "./dist/tl-header.css",
    "./tl-icon.css": "./dist/tl-icon.css",
    "./tl-link.css": "./dist/tl-link.css",
    "./tl-message.css": "./dist/tl-message.css",
    "./tl-modal.css": "./dist/tl-modal.css",
    "./tl-popover-canvas.css": "./dist/tl-popover-canvas.css",
    "./tl-popover-menu.css": "./dist/tl-popover-menu.css",
    "./tl-radio-button.css": "./dist/tl-radio-button.css",
    "./tl-text-field.css": "./dist/tl-text-field.css",
    "./tl-textarea.css": "./dist/tl-textarea.css",
    "./tl-toast.css": "./dist/tl-toast.css",
    "./tl-toggle.css": "./dist/tl-toggle.css",
    "./tl-tooltip.css": "./dist/tl-tooltip.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scania-digital-design-system/tegel.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prepublishOnly": "echo 'Warning: Run npm run build:tegel-lite from root before publishing'",
    "test": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^24.3.1",
    "serve": "^14.2.5"
  },
  "license": "MIT"
}
